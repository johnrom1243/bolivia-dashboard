# Copy this file to .env.local and fill in your values

# REQUIRED: Secret for NextAuth session signing
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# REQUIRED: Your deployment URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# REQUIRED: User credentials (add as many users as needed)
# Format: USER_1_NAME, USER_1_PASSWORD, USER_1_EMAIL
AUTH_USER_1_NAME=admin
AUTH_USER_1_PASSWORD=admin1
AUTH_USER_1_EMAIL=admin@yourcompany.com

AUTH_USER_2_NAME=analyst
AUTH_USER_2_PASSWORD=changeme456
AUTH_USER_2_EMAIL=analyst@yourcompany.com

# Optional: Company branding
NEXT_PUBLIC_COMPANY_NAME=Penfold
NEXT_PUBLIC_DASHBOARD_TITLE=Bolivia Intelligence Platform
